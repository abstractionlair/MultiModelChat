OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=...
GOOGLE_API_KEY=...
XAI_API_KEY=...
PORT=3000

# Optional: override per-provider smart defaults
# OPENAI_DEFAULT_MODEL=gpt-4o-mini
# ANTHROPIC_DEFAULT_MODEL=claude-3-7
# GOOGLE_DEFAULT_MODEL=gemini-2.0-pro-exp
# XAI_DEFAULT_MODEL=grok-4

# Optional: seed per-provider system prompt overrides (use {{modelId}} placeholder)
# OPENAI_DEFAULT_PROMPT="You are {{modelId}} ..."
# ANTHROPIC_DEFAULT_PROMPT="You are {{modelId}} ..."
# GOOGLE_DEFAULT_PROMPT="You are {{modelId}} ..."
# XAI_DEFAULT_PROMPT="You are {{modelId}} ..."

# Optional: cap provider output tokens (unset = no cap for providers that allow it)
# OPENAI_MAX_OUTPUT_TOKENS=
# ANTHROPIC_MAX_OUTPUT_TOKENS= # Anthropic requires a value; if unset, server uses 8192
# GOOGLE_MAX_OUTPUT_TOKENS=
# XAI_MAX_OUTPUT_TOKENS=

# Optional: transcript directory for exports and auto-save
# TRANSCRIPTS_DIR=transcripts

# PUBLIC_MODE guard — enable limits for public deployment
# PUBLIC_MODE=1
# PUBLIC_MODEL_ALLOWLIST=openai:gpt-4o-mini,anthropic:claude-3-haiku-20240307
# PUBLIC_MAX_TOKENS_PER_TURN=700
# PUBLIC_TURNS_PER_MIN=6
# PUBLIC_TURNS_PER_DAY=60
# PUBLIC_DAILY_TOKEN_BUDGET=2000000
# PUBLIC_WIPE_HOURS=24
